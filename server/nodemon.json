{
  "watch": ["app.js", "config", "controllers", "middlewares", "routes", "utils", ".env"],
  "ignore": ["node_modules", "logs", "coverage", "dist", "**/*.test.js"],
  "ext": "js,json,env",
  "exec": "node app.js",
  "env": {
    "NODE_ENV": "development",
    "MODE": "development"
  },
  "delay": 500,
  "verbose": true
}
